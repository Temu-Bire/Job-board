PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/careerconnect
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=development

# Google OAuth (server verifies ID tokens — must match VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Comma-separated list of allowed frontend origins for CORS + Socket.IO.
# Examples:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public URL of this API (no trailing slash). Required for disk uploads when the React app is on another domain.
# Example: https://your-service.onrender.com
PUBLIC_URL=

# Optional: Cloudinary for durable file storage on Render (recommended over local disk).
# If all three are set, avatars/resumes/logos upload to Cloudinary instead of ./uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Password reset email links
FRONTEND_URL=http://localhost:5173
