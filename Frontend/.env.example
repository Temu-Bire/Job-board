## Frontend environment variables (Vite)
#
# Dev (local):
# Leave VITE_API_BASE_URL empty to use Vite proxy (/api → http://127.0.0.1:5000)
#
# Prod (Vercel):
# Point to your Render backend:
# VITE_API_BASE_URL=https://YOUR-RENDER-SERVICE.onrender.com/api
VITE_API_BASE_URL=

# Optional: Socket.IO server URL (if not same origin)
# Example: https://YOUR-RENDER-SERVICE.onrender.com
VITE_SOCKET_URL=

