## Frontend (Vite) — copy to `.env` locally; set the same keys in Vercel/Netlify/hosting.

# API (required in production when UI is not served by the same host as the API)
# Example: https://your-service.onrender.com/api
VITE_API_BASE_URL=

# Legacy alias (optional — prefer VITE_API_BASE_URL)
# VITE_API_URL=

# Backend origin without `/api` — used for `/uploads/...` and as fallback for Socket.IO
# Example: https://your-service.onrender.com
VITE_BACKEND_ORIGIN=

# Socket.IO server (usually same as backend origin). If unset, VITE_BACKEND_ORIGIN is used.
# VITE_SOCKET_URL=https://your-service.onrender.com

# Google Sign-In (Web client ID)
VITE_GOOGLE_CLIENT_ID=
